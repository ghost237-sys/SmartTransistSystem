{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://smarttransistsystem-production.up.railway.app/api/:path*"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}